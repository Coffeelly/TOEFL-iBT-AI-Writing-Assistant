# =============================================================================
# TOEFL Helper — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to the repository.
# =============================================================================

# Database provider: "sqlite" for local dev, "postgresql" for prod
DATABASE_PROVIDER="sqlite"

# SQLite (dev): file path relative to prisma/
DATABASE_URL="file:./dev.db"

# PostgreSQL (prod-equivalent via Docker):
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://toefl_user:toefl_pass@localhost:5432/toefl_helper"
# DIRECT_URL="postgresql://toefl_user:toefl_pass@localhost:5432/toefl_helper"

# Authentication
JWT_SECRET="your-jwt-secret-here-min-32-characters"
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
